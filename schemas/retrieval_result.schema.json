{
  "$defs": {
    "EvidenceGroup": {
      "properties": {
        "group_id": {
          "title": "Group Id",
          "type": "string"
        },
        "group_type": {
          "title": "Group Type",
          "type": "string"
        },
        "members": {
          "items": {
            "type": "string"
          },
          "title": "Members",
          "type": "array"
        }
      },
      "required": [
        "group_id",
        "group_type",
        "members"
      ],
      "title": "EvidenceGroup",
      "type": "object"
    },
    "EvidenceItem": {
      "properties": {
